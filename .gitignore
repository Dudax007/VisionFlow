# ==========================================
# VisionFlow — .gitignore
# ==========================================

# Variáveis de ambiente e segredos
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# Dependências
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Build / Output
dist/
build/
coverage/
out/
.output/

# Cache
.cache/
.parcel-cache/
.vite/
.eslintcache
.stylelintcache

# Sistema Operacional
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editores e IDEs
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# Ferramentas de desenvolvimento locais
.gemini/
.anthropic/

# Testes
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Temporários
tmp/
temp/
*.tmp
*.bak
*.backup
